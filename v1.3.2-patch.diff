-    if optional in secrets and secrets[optional]:
-        info[optional] = secrets[optional]
-with open('$B/Contents/Info.plist', 'wb') as f:
-    plistlib.dump(info, f)
-print('Secrets merged into Info.plist')
-"
-fi
